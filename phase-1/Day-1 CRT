//Swap values of 2 variables using 3rd variable

#include<iostream>
using namespace std;

int main(){
    int a;
    int b;
    
    cin >> a >> b;
    //swapping logic
    int temp = a;
    a = b;
    b = temp;
    
    cout << a << "\n" << b << endl;
    return 0;
}
