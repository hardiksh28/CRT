#include<iostream>
using namespace std;

//Problem 1
//Inheritance
//Type 1.1 - single Inheritance

class Vehicle {
public:
	void start() {
		cout << "Vehicle Starts" << "\n";
	}
};

class Car : public Vehicle{
public:
	void drive() {
		cout<<"Car is running"<<"\n";
	}
};

int main() {
	Car obj1;
	obj1.drive();
	obj1.start();

}
