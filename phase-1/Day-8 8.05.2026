#include<iostream>
using namespace std;

//Problem 1
//Inheritance
//Type 1.3 - Heirarichal Inheritance

class Vehicle {
public:
	void start() {
		cout << "Vehicle Starts" << "\n";
	}
};

class Car : public Vehicle {
public:
	void drive() {
		cout<<"Car is running"<<"\n";
	}
};

class Bike : public Vehicle {
public:
	void ignition() {
		cout<<"Bike is running"<<"\n";
	}
};

int main() {
	Car obj1;
	Bike obj2;
	obj1.start();
	obj1.drive();
	obj2.ignition();
}

