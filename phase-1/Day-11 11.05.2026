Leetcode 189

class Solution {
public:

void rotateArray(vector<int>& nums, int start, int end){
    while(start < end){
        swap(nums[start], nums[end]);
        start++;
        end--;
    }
}
    void rotate(vector<int>& nums, int k) {
        int n = nums.size();
        k = k%n;
        rotateArray(nums, 0, n-1);
        rotateArray(nums, 0, k-1);
        rotateArray(nums, k, n-1);
    }
};
