//Palindrome question where we used pointers approach for checking
//Exampler - NAMAN is a palindrome but HARDIK is not

#include <iostream>
using namespace std;

bool isPalindrome(string str){
    int start = 0;
    int end = str.size() - 1;
    
    while(start<end){
        if(str[start] != str[end]){
            return false;
        }
        start++;
        end--;
    }
    return true;
}

int main(){
    string str;
    cout << "Enter a string...";
    cin >> str;
    
    if(isPalindrome(str)){
        cout << "Palindrome string";
    }else{
        cout << "Given string is not a Palindrome";
    }
    return 0;
}

