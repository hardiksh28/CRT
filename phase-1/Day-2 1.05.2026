//Problem-1 -- If - else condition
//to verify users age wether wligible for vote or not?
#include<iostream>
using namespace std;

int main (){
    int age;
    cin >> age;
    //if condition
    if(age >= 18){
        //logic
        cout << "Eligible for vote";
    }else{
        //logic
        cout << "Not eligible for vote";
    }
    return 0;
}

