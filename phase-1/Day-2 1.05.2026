//Problem -1 -- IF condition
//to verify users age wether eligible for vote or not
#include<iostream>
using namespace std;

int main (){
    int age;
    cin >> age;
    //if condition
    if(age >=18){
        //logic
        cout << "Eligible for vote";
    }
    return 0;
}

