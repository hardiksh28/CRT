//Problem 4 -- Ternary operator
//Find greater number among int32_t
#include<iostream>
using namespace std;

int main(){
    int a,b;
    int max_Number;
    
    cin >>a >>b;
    //Ternary operator
    max_Number = (a>b) ? a:b;
    
    cout << max_Number;
    return 0;
}

-----------------------

//Problem 5 --Continue Statement
//Print 1 to N and avoid those number which are not divisible by 3
#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    
    for(int i = 1;i<=n; i++){
        if(i%3 == 0){
            continue;
        }
        cout << i << " ";
    }
    cout << '\n';
    return 0;
}
