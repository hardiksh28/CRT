 💎 PROBLEM 01: NUMBER GRID 🔢
 📝 Task: Print 1-10 in 10 rows
 🖼️ Pattern:
 1 2 3 ... 10
 1 2 3 ... 10
 ==============================================

 #include <iostream>
 using namespace std;
 int main()
 {
     for(int i = 1; i <= 10; i++) {
         for(int j = 1; j <= 10; j++){
             cout << j << " ";
         }
         cout << "\n";
     }
     return 0;
 }
