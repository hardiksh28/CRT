//Traversing

#include<iostream>
using namespace std;

class Node{
    int data;
    Node* next;
    
    Node(int new_data){
        this-> data = new_data;
        this->next = nullptr;
    }
};

Node* head = nullptr;
void traversal(){
    while(head !=nullptr){
        cout << head->data << " ";
        head = head->next;a
    }
}

int main(){
    head = new Node(10);
    head->next = new Node(20);
    head->next->next = new Node(30);
    head->next->next->next = new Node(40);
    traversal();
    return 0;
}
