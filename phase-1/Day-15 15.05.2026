//Reverse array using stack
#include<iostream>
#include<stack>
using namespace std;

int main(){
    int arr[]={10,20,30,40,50};
    int n=5;
    
    stack<int> st;
    //Java -- Stack<Integer> st = new Stack<>();
    //push the data into the Stack
    for(int i =0; i<n; i++){
        st.push(arr[i]);
    }
    //pop the data from the stack and put into the array back
    for(int i=0; i<n; i++){
        arr[i] = st.top();
        st.pop();
    }
    
    cout << "Reversed array.."<<"\n";
    
    for(int i =0;i<n ; i++){
        cout<< arr[i]<< " ";
    }
    
    return 0;    
    }

------------------
//Leetcode 344

class Solution {
public:
    void reverseString(vector<char>& s) {
        stack<char> st;

        for(int i =0;i <s.size(); i++){
            st.push(s[i]);
        }
        int i = 0;
        while(!st.empty()){
            s[i++] = st.top();
            st.pop();
        }
    }
};

