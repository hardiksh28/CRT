//Problem 6 
//Pointers

#include<iostream>
using namespace std;

int main(){
    
    int age = 24;
    int *ptr = &age;
    
    cout << age << "\n";
    cout << ptr << "\n";
    cout << *ptr;
}

-------------------------------

//Problem 7
// sum of 2 numbers using pointers

#include<iostream>
using namespace std;

int main(){
    int a,b;
    cin >> a;
    cin >> b;
    
    int *ptr1 = &a;
    int *ptr2 = &b;
    
    int sum = *ptr1 + *ptr2;
    cout << sum;
}
