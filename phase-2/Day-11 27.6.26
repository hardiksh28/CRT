Undirected and unweighted graph - matrix

#include <iostream>
using namespace std;


class Graph {

private:
    int** adjacencyMatrix;
    int nodes;

public:

    Graph(int n) {

        nodes = n;
        adjacencyMatrix = new int*[nodes];

        for (int i = 0; i < nodes; ++i) {

            adjacencyMatrix[i] = new int[nodes];
            for (int j = 0; j < nodes; ++j) {
                adjacencyMatrix[i][j] = 0;
            }
            
        }


    }


    // Add Edge (Undirected)
    void addEdge(int source, int destination) {

        adjacencyMatrix[source][destination] = 1;

        adjacencyMatrix[destination][source] = 1;

    }


    // Display Matrix
    void showMatrix() {
        for (int i = 0; i < nodes; ++i) {
            for (int j = 0; j < nodes; ++j) {
                cout << adjacencyMatrix[i][j] << " ";
            }
            cout << endl;
        }
    }


    // Destructor to free memory
    ~Graph() {
        for (int i = 0; i < nodes; ++i) {
            delete[] adjacencyMatrix[i];
        }
        delete[] adjacencyMatrix;
    }
};

// DRIVER CODE
int main() {
    // There are 6 nodes: A, B, C, D, E, F
    int totalNodes = 6;

    Graph g(totalNodes);

    // Adding edges based on the provided graph:
    g.addEdge(0, 1); // A-B
    g.addEdge(0, 5); // A-F
    g.addEdge(1, 2); // B-C
    g.addEdge(1, 5); // B-F
    g.addEdge(2, 3); // C-D
    g.addEdge(2, 4); // C-E
    g.addEdge(3, 4); // D-E
    g.addEdge(4, 5); // E-F

    cout << "Adjacency Matrix:\n";
    g.showMatrix();

    return 0;
}
