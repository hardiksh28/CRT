C++ code demonstrates how to use a priority queue, specifically acting as a max heap
Output - 30 20 10 5

#include<iostream>
#include<queue>
using namespace std;

int main(){
    priority_queue<int> pq; // max heap: largest elemnt on top
    
    pq.push(10);
    pq.push(30);
    pq.push(20);
    pq.push(5);
    
    cout << "Top element: "<< pq.top()<< endl; //30
    
    while(!pq.empty()){
        cout << pq.top() << " ";
        pq.pop();
    }
    //Output: 30 20 10 5
    
    return 0;
}

-----------------------
Output changed to - 5 10 20 30

#include<iostream>
#include<queue>
using namespace std;

int main(){
    priority_queue<int, vector<int>, greater <int>>  pq; // max heap: largest elemnt on top
    
    pq.push(10);
    pq.push(30);
    pq.push(20);
    pq.push(5);
    
    cout << "Top element: "<< pq.top()<< endl; //30
    
    while(!pq.empty()){
        cout << pq.top() << " ";
        pq.pop();
    }
    //Output: 30 20 10 5
    
    return 0;
}
