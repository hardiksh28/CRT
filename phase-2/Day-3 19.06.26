Leetcode #74

class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) {
        
        int m = matrix.size();
        int n = matrix[0].size();
        
        if(m == 0) return false;

        int low = 0, high = (m * n) -1;

        while(low <= high){
            int mid = low + (high - low)/2;

            int row = mid/n;
            int col = mid%n;
            int midValue = matrix[row][col];

            if(midValue == target)
            return true;
            else if(midValue < target)
            low = mid +1;
            else
            high = mid -1;
        }
        return false;
    }
};
